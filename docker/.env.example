# Radiant Node Configuration
RADIANT_NODE_RPCUSER=your_rpc_username_here
RADIANT_NODE_RPCPASSWORD=your_rpc_password_here

# PostgreSQL Configuration
POSTGRES_DB=rxindexer
POSTGRES_USER=rxindexer
POSTGRES_PASSWORD=your_postgres_password_here

# JWT Secret Key (generate a strong random string)
JWT_SECRET_KEY=your_jwt_secret_key_here_minimum_32_characters

# MinIO Object Storage (for token files)
MINIO_ROOT_USER=rxindexer
MINIO_ROOT_PASSWORD=your_minio_password_here

# Redis Configuration (optional - falls back to in-memory cache if not set)
REDIS_URL=redis://redis:6379/0

# API Configuration
RXD_BIND_IP=127.0.0.1

# Indexer Configuration
ENABLE_AUTOMATED_BACKFILLS=1
BACKFILL_MAX_SYNC_LAG=10
SPENT_BACKFILL_TIME_BUDGET_SECONDS=30
BACKFILL_LOOP_SLEEP_SECONDS=60
SPENT_BACKFILL_TIME_BUDGET_SECONDS_NEAR_SYNC=60
BACKFILL_LOOP_SLEEP_SECONDS_NEAR_SYNC=30
SPENT_BACKFILL_SLEEP_SECONDS_NEAR_SYNC=0.05
SPENT_BACKFILL_BATCH_SIZE_NEAR_SYNC=20000
SPENT_BACKFILL_TIME_BUDGET_SECONDS_CAUGHT_UP=200
BACKFILL_LOOP_SLEEP_SECONDS_CAUGHT_UP=10
SPENT_BACKFILL_SLEEP_SECONDS_CAUGHT_UP=0
SPENT_BACKFILL_BATCH_SIZE_CAUGHT_UP=100000
SYNC_POLL_INTERVAL_CAUGHT_UP=120
SKIP_SPENT_CHECK=auto
SKIP_SPENT_CHECK_THRESHOLD=1000
USE_COPY=1
PYTHONUNBUFFERED=1
