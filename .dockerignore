# Database directories (large, mounted as volumes — must never be copied
# into the image). Patterns cover both upstream layouts and stray dirs that
# operators sometimes leave under docker/full-stack/.
electrumx-db/
electrumx-db-*/
electrumdb/
electrumdb-*/
electrumdb.*/
**/electrumdb/
**/electrumdb-*/
**/electrumdb.*/
**/*.sst
**/*.ldb

# Python virtual environment
venv/
__pycache__/
*.pyc
*.pyo

# Git
.git/

# Test artifacts
.pytest_cache/
*.log
*.pid

# IDE
.vscode/
.idea/

# Benchmarks
benchmarks/

# Docker (avoid recursion)
docker/full-stack/*.tar.gz
*.zip
