# RXinDexer Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================================================
# RADIANT NODE CONFIGURATION (Required)
# ============================================================================
RADIANT_NODE_HOST=radiant-node
RADIANT_NODE_RPCUSER=your_rpc_username
RADIANT_NODE_RPCPASSWORD=your_secure_rpc_password_min_8_chars
RADIANT_NODE_RPCPORT=7332
RADIANT_NODE_RESTPORT=7333

# ============================================================================
# POSTGRESQL CONFIGURATION (Required)
# ============================================================================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=rxindexer
POSTGRES_USER=rxindexer
POSTGRES_PASSWORD=your_secure_db_password_min_8_chars

# ============================================================================
# API SECURITY (Required for Production)
# ============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=generate_a_secure_random_key_here_min_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# OPTIONAL: Indexer Configuration
# ============================================================================
ENABLE_AUTOMATED_BACKFILLS=1
BACKFILL_MAX_SYNC_LAG=10
SKIP_SPENT_CHECK=auto
USE_COPY=1

# ============================================================================
# OPTIONAL: Redis Cache (for multi-instance deployments)
# ============================================================================
# Leave empty to use in-memory cache (suitable for single instance)
# Set for horizontal scaling with shared cache across instances
REDIS_URL=

# ============================================================================
# OPTIONAL: Bind IP (use 0.0.0.0 for external access, 127.0.0.1 for local only)
# ============================================================================
RXD_BIND_IP=127.0.0.1
